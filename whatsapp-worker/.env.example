# Shared VPS secret — the website sends this as the x-api-key header. Make it
# long and random; set the SAME value as VPS_API_SECRET on the website (Vercel).
# Reusable as the auth secret for other services you host on this VPS too.
VPS_API_SECRET=change_me_to_a_long_random_string

# Port the HTTP API listens on. On Pterodactyl LEAVE THIS UNSET — the worker
# auto-binds the panel's allocated port (SERVER_PORT). Only set PORT for a
# plain VPS where you choose the port yourself.
# PORT=8080

# OPTIONAL console fallback. Normally you LINK FROM THE ADMIN PANEL
# (Settings → WhatsApp → enter number → pairing code) and leave this blank.
# If set, the worker also prints a pairing code for this number on boot.
# WA_PAIRING_NUMBER=919876543210

# ── Cloudflare Tunnel (expose this worker on a domain, no shell needed) ──
# Set CF_HOSTNAME to enable it. On first boot the console prints a one-time
# authorize URL — open it, pick the ghumakkars.in zone, done. Everything
# (binary, cert, creds) is stored inside this folder so it survives restarts.
CF_HOSTNAME=api.ghumakkars.in
# CF_TUNNEL_NAME=ghumakkars-api   # optional; defaults to the hostname

# OPTIONAL backup so the tunnel survives a FULL reinstall (volume wipe). After
# first setup the console prints these as base64 — paste them back here.
# CF_CERT=
# CF_CREDS=
