# Shared secret — the website sends this as the x-api-key header. Make it long
# and random; set the SAME value as WHATSAPP_API_SECRET on the website (Vercel).
WHATSAPP_API_SECRET=change_me_to_a_long_random_string

# Port the HTTP API listens on (point api.ghumakkars.in at this).
PORT=8080

# Headless login: the WhatsApp number that will SEND (country code, digits only).
# On first run the console prints an 8-char pairing code to type into WhatsApp.
# Leave blank to use a QR instead.
WA_PAIRING_NUMBER=919876543210
