# Shared VPS secret — the website sends this as the x-api-key header. Make it
# long and random; set the SAME value as VPS_API_SECRET on the website (Vercel).
# Reusable as the auth secret for other services you host on this VPS too.
VPS_API_SECRET=change_me_to_a_long_random_string

# Port the HTTP API listens on. On Pterodactyl LEAVE THIS UNSET — the worker
# auto-binds the panel's allocated port (SERVER_PORT). Only set PORT for a
# plain VPS where you choose the port yourself.
# PORT=8080

# Headless login: the WhatsApp number that will SEND (country code, digits only).
# On first run the console prints an 8-char pairing code to type into WhatsApp.
# Leave blank to use a QR instead.
WA_PAIRING_NUMBER=919876543210
